{
  "expo": {
    "name": "Stack",
    "slug": "stack-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "stackapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.stackapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1f3a2c",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.stackapp"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f1d8e7",
          "dark": {
            "backgroundColor": "#26182f"
          }
        }
      ],
      "expo-font"
    ]
  }
}
