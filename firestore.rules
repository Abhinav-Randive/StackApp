rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function stackDoc(stackId) {
      return get(/databases/$(database)/documents/stacks/$(stackId));
    }

    function isStackMember(stackId) {
      return signedIn() && request.auth.uid in stackDoc(stackId).data.members;
    }

    function isStackOwner(stackId) {
      return signedIn() && stackDoc(stackId).data.owner_id == request.auth.uid;
    }

    function ownsContribution() {
      return signedIn() && isStackOwner(resource.data.stack_id);
    }

    function ownsActivity() {
      return signedIn() && resource.data.stack_id != null && isStackOwner(resource.data.stack_id);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId);
      allow delete: if false;
    }

    match /stacks/{stackId} {
      allow read: if signedIn() && request.auth.uid in resource.data.members;
      allow create: if signedIn()
        && request.resource.data.owner_id == request.auth.uid
        && request.auth.uid in request.resource.data.members;
      allow update: if signedIn() && request.auth.uid in resource.data.members;
      allow delete: if signedIn() && resource.data.owner_id == request.auth.uid;
    }

    match /contributions/{contributionId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.user_id == request.auth.uid
        && isStackMember(request.resource.data.stack_id);
      allow update: if false;
      allow delete: if ownsContribution();
    }

    match /activities/{activityId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if ownsActivity();
    }

    match /notifications/{notificationId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if ownsActivity();
    }
  }
}
